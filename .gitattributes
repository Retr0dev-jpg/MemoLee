# Force LF line endings for all text files, both in the repo and on checkout.
* text=auto eol=lf

# Binary assets: never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary
